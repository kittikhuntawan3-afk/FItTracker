<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#ffffff">
<title>FitTracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root{
  /* Miro canvas & surfaces */
  --bg:#ffffff;--surface:#f7f8fa;--surface2:#fafbfc;--border:#e0e2e8;--border-soft:#eef0f3;--border-strong:#c7cad5;
  /* Miro brand */
  --yellow:#ffd02f;--yellow-deep:#fcb900;--yellow-light:#fff8e0;--yellow-dark:#746019;
  --blue:#4262ff;--blue-pressed:#2a41b6;--teal:#0fbcb0;--teal-light:#c3faf5;
  --coral:#ff9999;--coral-light:#ffc6c6;--coral-dark:#600000;
  --rose:#fde0f0;--orange-light:#ffe6cd;--orange:#ff8c00;--green:#00b473;
  /* Miro ink */
  --text:#1c1c1e;--text2:#6b6f7e;--text3:#8e91a0;--text-muted:#a5a8b5;
  /* Aliases used throughout app */
  --accent:#ffd02f;--accent2:#4262ff;--gold:#ffd02f;
  /* Layout */
  --nav-h:64px;--hdr-h:60px;--radius:16px;--radius-pill:9999px;--radius-feature:28px;
  --safe-b:env(safe-area-inset-bottom,0px);
  /* Miro shadows (ink-deep based) */
  --shadow-sm:rgba(5,0,56,.04) 0px 1px 2px 0px;
  --shadow-md:rgba(5,0,56,.06) 0px 4px 12px 0px;
  --shadow-lg:rgba(5,0,56,.08) 0px 12px 32px -4px;
  --shadow-xl:rgba(5,0,56,.12) 0px 16px 48px -8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{height:100%;height:-webkit-fill-available}body{height:100%;min-height:-webkit-fill-available;overflow:hidden;background:var(--bg);color:var(--text);font-family:'Plus Jakarta Sans','Noto Sans',system-ui,-apple-system,sans-serif}

/* ── Shell ── */
.app{display:flex;flex-direction:column;height:100vh;min-height:-webkit-fill-available;height:100dvh;overflow:hidden}

/* ── Header ── */
.top-hdr{height:var(--hdr-h);background:var(--bg);border-bottom:1px solid var(--border-soft);
  display:flex;align-items:center;justify-content:space-between;padding:0 16px;flex-shrink:0;z-index:10}
.logo{font-size:20px;font-weight:700;color:var(--text);letter-spacing:-.3px}
.logo span{color:var(--yellow-deep)}
.lv-pill{display:flex;align-items:center;gap:8px;background:var(--text);
  border-radius:var(--radius-pill);padding:6px 14px 6px 10px;cursor:pointer}
.lv-pill .lv-num{font-size:11px;font-weight:700;color:var(--text);background:var(--yellow);
  border-radius:var(--radius-pill);padding:2px 7px;line-height:1.4}
.lv-pill .lv-name{font-size:12px;font-weight:500;color:#fff}
.xp-mini{width:44px;height:3px;background:rgba(255,255,255,.25);border-radius:99px;overflow:hidden;margin-top:2px}
.xp-mini-fill{height:100%;background:var(--yellow);border-radius:99px;transition:width .5s}

/* ── Pages ── */
.pages{flex:1;overflow:hidden;position:relative}
.page{position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;
  padding:16px 16px calc(var(--nav-h) + var(--safe-b) + 24px);
  display:none;-webkit-overflow-scrolling:touch}
.page.active{display:block;animation:slideUp .2s cubic-bezier(.4,0,.2,1)}
@keyframes slideUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.page::-webkit-scrollbar{display:none}

/* ── Bottom Nav ── */
.bot-nav{position:fixed;bottom:0;left:0;right:0;height:calc(var(--nav-h) + var(--safe-b));padding-bottom:var(--safe-b);
  background:var(--bg);border-top:1px solid var(--border-soft);display:flex;flex-shrink:0;z-index:20}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;border:none;background:none;color:var(--text3);cursor:pointer;padding:8px 4px;transition:color .15s}
.ni.active{color:var(--text)}
.ni.active .lbl{color:var(--text);font-weight:600}
.ni .ico{font-size:22px;transition:transform .15s}
.ni.active .ico{transform:scale(1.1)}
.ni .lbl{font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.4px}

/* ── FAB ── */
.fab{position:fixed;right:20px;bottom:calc(var(--nav-h) + var(--safe-b) + 14px);
  width:56px;height:56px;border-radius:var(--radius-pill);background:var(--text);border:none;
  color:#fff;font-size:26px;display:flex;align-items:center;justify-content:center;
  box-shadow:var(--shadow-lg);cursor:pointer;z-index:30;transition:all .15s}
.fab:active{transform:scale(.93);background:var(--charcoal,#2c2c34)}
.fab.hide{opacity:0;pointer-events:none;transform:scale(.8)}

/* ── Cards / common ── */
.card{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);padding:16px;margin-bottom:12px;box-shadow:var(--shadow-md)}
.sec-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;
  letter-spacing:.5px;margin:18px 0 10px}
.sec-title:first-child{margin-top:0}

/* ── Stats row 2-col ── */
.s2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.s-cell{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);padding:14px;box-shadow:var(--shadow-md)}
.s-lbl{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;font-weight:500}
.s-val{font-size:26px;font-weight:600;margin-top:2px;line-height:1}
.s-sub{font-size:11px;color:var(--text2);margin-top:2px}

/* ── Workout item ── */
.wi{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--bg);
  border-radius:var(--radius);margin-bottom:8px;border:1px solid var(--border-soft);box-shadow:var(--shadow-sm)}
.wi-ico{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;
  justify-content:center;font-size:20px;flex-shrink:0}
.wis{background:var(--rose)}.wic{background:var(--teal-light)}
.wi-info{flex:1;min-width:0}
.wi-name{font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wi-meta{font-size:12px;color:var(--text2);margin-top:2px}
.wi-xp{font-size:11px;font-weight:600;color:var(--yellow-dark);white-space:nowrap;background:var(--yellow-light);padding:2px 8px;border-radius:var(--radius-pill)}
.wi-del{background:none;border:none;color:var(--text3);font-size:18px;padding:6px;cursor:pointer;flex-shrink:0}
.wi-gcal{font-size:16px;padding:6px;text-decoration:none;flex-shrink:0;line-height:1;display:flex;align-items:center;opacity:.6}.wi-gcal:hover{opacity:1}
.wi-rep{background:none;border:none;color:var(--text2);font-size:13px;padding:5px 12px;
  border-radius:var(--radius-pill);border:1px solid var(--border-strong);cursor:pointer;white-space:nowrap;font-weight:500}
.wi-rep:active{background:var(--surface)}

/* ── XP bar ── */
.xp-bg{height:8px;background:var(--border-soft);border-radius:99px;overflow:hidden}
.xp-fill{height:100%;background:var(--yellow);border-radius:99px;transition:width .6s}

/* ── Calendar ── */
.cal-nav-r{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.cal-nav-b{width:36px;height:36px;border-radius:var(--radius-pill);background:var(--surface);
  border:1px solid var(--border-soft);color:var(--text);font-size:18px;
  display:flex;align-items:center;justify-content:center;cursor:pointer}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cdn{text-align:center;font-size:10px;color:var(--text2);font-weight:700;padding:4px 0;text-transform:uppercase}
.cday{aspect-ratio:1;border-radius:8px;display:flex;flex-direction:column;align-items:center;
  justify-content:center;font-size:12px;font-weight:700;border:1.5px solid transparent;
  background:var(--surface2);cursor:pointer;position:relative}
.cday.empty{background:none;border:none;cursor:default}
.cday.today{border-color:var(--text);background:var(--text);color:#fff}
.cday.has-s{background:var(--rose)}
.cday.has-c{background:var(--teal-light)}
.cday.has-b{background:var(--yellow-light)}
.cday.has-plan{box-shadow:0 0 0 1.5px var(--border) inset}
.cday.sel{outline:2px solid var(--text);outline-offset:1px}
.cday-dot{width:4px;height:4px;border-radius:50%;margin-top:2px}
.plan-dot{width:4px;height:4px;border-radius:50%;background:var(--gold);position:absolute;bottom:3px;right:3px}

/* ── Buttons ── */
.btn{padding:12px 22px;border-radius:var(--radius-pill);border:none;font-size:14px;font-weight:600;
  cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px}
.btn:active{transform:scale(.97)}
.btn-p{background:var(--text);color:#fff;box-shadow:var(--shadow-md)}
.btn-p:hover{background:#3a3a3a}
.btn-s{background:var(--bg);color:var(--text);border:1.5px solid var(--border-strong)}
.btn-s:hover{background:var(--surface)}
.btn-d{background:transparent;color:#EF4444;border:1.5px solid rgba(239,68,68,.4)}
.btn-d:hover{background:rgba(239,68,68,.06)}
.btn-sm{padding:7px 16px;font-size:13px}
.btn-blk{width:100%;justify-content:center}

/* ── GitHub Sync ── */
.sync-btn{background:none;border:none;cursor:pointer;font-size:20px;padding:4px 6px;border-radius:8px;color:var(--text2);transition:color .15s}
.sync-btn:hover{color:var(--text)}
.sync-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;
  padding:3px 10px;border-radius:var(--radius-pill);cursor:pointer;transition:all .2s;border:1px solid transparent;background:none}
.sync-badge.idle{color:var(--text3);background:var(--surface);border-color:var(--border-soft)}
.sync-badge.syncing{color:var(--teal);background:var(--teal-light);border-color:var(--teal);animation:pulse .8s infinite}
.sync-badge.ok{color:var(--green);background:var(--teal-light);border-color:var(--green)}
.sync-badge.err{color:#DC2626;background:var(--coral-light);border-color:var(--coral)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.gh-info{font-size:12px;color:var(--text2);margin-top:4px}
.gh-token-row{display:flex;gap:8px;align-items:center}
.gh-toggle{background:none;border:none;color:var(--blue);cursor:pointer;font-size:13px;white-space:nowrap}

/* ── Bottom Sheet ── */
.sov{position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);
  z-index:50;opacity:0;pointer-events:none;transition:opacity .25s}
.sov.open{opacity:1;pointer-events:all}
.sheet{position:fixed;left:0;right:0;bottom:0;background:var(--bg);
  border-radius:24px 24px 0 0;border-top:1px solid var(--border-soft);z-index:51;
  transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);
  max-height:93dvh;max-height:93vh;display:flex;flex-direction:column;box-shadow:var(--shadow-xl)}
.sov.open .sheet{transform:translateY(0)}
.sh-handle{width:36px;height:4px;background:var(--border-soft);border-radius:99px;margin:10px auto 0;flex-shrink:0}
.sh-head{padding:14px 20px 12px;flex-shrink:0;border-bottom:1px solid var(--border-soft)}
.sh-title{font-size:18px;font-weight:700}
.sh-sub{font-size:13px;color:var(--text2);margin-top:2px}
.sh-body{padding:16px 20px;overflow-y:auto;flex:1;-webkit-overflow-scrolling:touch}
.sh-body::-webkit-scrollbar{display:none}
.sh-foot{padding:12px 20px calc(var(--safe-b) + 12px);border-top:1px solid var(--border-soft);
  display:flex;gap:10px;flex-shrink:0}

/* ── Form ── */
.fg{margin-bottom:14px}
.fl{display:block;font-size:12px;font-weight:500;color:var(--text2);
  letter-spacing:.2px;margin-bottom:6px}
.fi{width:100%;background:var(--bg);border:1.5px solid var(--border-strong);border-radius:var(--radius);
  color:var(--text);padding:12px 14px;font-size:15px;outline:none;transition:border-color .15s,box-shadow .15s;
  -webkit-appearance:none;box-shadow:none}
.fi:hover{border-color:var(--text2)}
.fi:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(66,98,255,.15)}
.fsel{width:100%;background:var(--bg);border:1.5px solid var(--border-strong);border-radius:var(--radius);
  color:var(--text);padding:12px 14px;font-size:15px;outline:none;-webkit-appearance:none}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}

/* ── Segmented control ── */
.seg{display:flex;background:var(--surface);border-radius:var(--radius-pill);padding:4px;gap:3px;
  margin-bottom:14px;border:1px solid var(--border-soft)}
.seg-b{flex:1;padding:9px;border-radius:var(--radius-pill);border:none;background:none;
  color:var(--text2);font-size:14px;font-weight:500;cursor:pointer;transition:all .2s}
.seg-b.on{background:var(--text);color:#fff;box-shadow:var(--shadow-sm)}
.seg-b[data-t=cardio].on{background:var(--text);color:#fff}

/* ── Chips / filters ── */
.chips{display:flex;gap:7px;overflow-x:auto;margin-bottom:12px;padding-bottom:2px}
.chips::-webkit-scrollbar{display:none}
.chip{padding:6px 14px;border-radius:var(--radius-pill);font-size:13px;font-weight:500;white-space:nowrap;
  cursor:pointer;border:1px solid var(--border-soft);background:var(--surface);color:var(--text2);
  flex-shrink:0;transition:all .15s}
.chip.on{background:var(--yellow-light);border-color:var(--yellow-deep);border-width:1.5px;color:var(--yellow-dark)}

/* ── Empty ── */
.empty{text-align:center;padding:36px 16px;color:var(--text2)}
.ei{font-size:38px;margin-bottom:10px}
.et{font-size:13px;line-height:1.5}

/* ── Week strip ── */
.wstrip{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:12px}
.wcell{display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 2px;
  border-radius:10px;border:1.5px solid transparent}
.wcell.today-c{border-color:var(--yellow-deep);background:var(--yellow-light)}
.wcell .wd{font-size:10px;color:var(--text2);font-weight:700;text-transform:uppercase}
.wcell .wico{font-size:14px}

/* ── Split bar ── */
.sbar-row{margin-bottom:10px}
.sbar-lbl{display:flex;justify-content:space-between;font-size:13px;margin-bottom:5px}
.sbar-bg{height:8px;background:var(--border);border-radius:99px;overflow:hidden}
.sbar-fill{height:100%;border-radius:99px;transition:width .5s}

/* ── SVG Charts ── */
.chart-wrap{position:relative;width:100%;overflow:hidden;border-radius:10px}
.chart-wrap svg{display:block;width:100%;overflow:visible}
.chart-label{fill:var(--text2);font-size:10px;font-family:inherit}
.chart-line{fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}

/* ── Weight log ── */
.w-entry{display:flex;align-items:center;gap:10px;padding:10px 13px;background:var(--surface2);
  border-radius:10px;margin-bottom:7px;border:1px solid var(--border)}
.w-entry-val{font-size:18px;font-weight:700;color:var(--text);white-space:nowrap}
.w-entry-date{font-size:12px;color:var(--text2);flex:1}
.w-entry-del{background:none;border:none;color:var(--text2);font-size:16px;cursor:pointer;padding:4px}
.w-stat-pill{display:inline-flex;flex-direction:column;align-items:center;padding:10px 16px;
  background:var(--surface2);border-radius:12px;border:1px solid var(--border)}
.w-stat-pill .v{font-size:20px;font-weight:800}
.w-stat-pill .l{font-size:11px;color:var(--text2);margin-top:1px}

/* ── Weekly Schedule ── */
.wd-picker{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.wd-btn{width:36px;height:36px;border-radius:9px;background:var(--surface2);
  border:1.5px solid var(--border);color:var(--text2);font-size:11px;font-weight:700;
  cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.wd-btn.on{background:color-mix(in srgb,var(--plan-c,var(--accent)) 20%,transparent);
  border-color:var(--plan-c,var(--accent));color:var(--plan-c,var(--accent))}

/* ── Today's plan banner ── */
.today-banner{background:var(--yellow-light);
  border:1px solid var(--yellow-deep);border-radius:var(--radius);padding:14px;margin-bottom:12px;box-shadow:var(--shadow-sm)}
.tb-top{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.tb-ico{font-size:26px}
.tb-name{font-size:15px;font-weight:800}
.tb-sub{font-size:12px;color:var(--text2);margin-top:1px}
.tb-days{display:flex;gap:7px;flex-wrap:wrap}
.tb-day-btn{padding:6px 13px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer}

/* ── Plan cards ── */
.plan-card{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);
  margin-bottom:12px;overflow:hidden;box-shadow:var(--shadow-md)}
.plan-card.act-plan{border-color:var(--yellow-deep);box-shadow:var(--shadow-md)}
.pc-head{padding:16px;background:linear-gradient(135deg,color-mix(in srgb,var(--plan-c,var(--accent)) 14%,transparent),transparent);
  display:flex;align-items:flex-start;gap:12px}
.p-ico{width:48px;height:48px;border-radius:13px;display:flex;align-items:center;justify-content:center;
  font-size:24px;background:color-mix(in srgb,var(--plan-c,var(--accent)) 18%,var(--surface2));flex-shrink:0}
.p-info{flex:1;min-width:0}
.p-name{font-size:16px;font-weight:800}
.p-desc{font-size:12px;color:var(--text2);margin-top:2px}
.p-badge{display:inline-flex;align-items:center;gap:4px;background:color-mix(in srgb,var(--plan-c,var(--accent)) 18%,transparent);
  border:1px solid color-mix(in srgb,var(--plan-c,var(--accent)) 35%,transparent);
  color:var(--plan-c,var(--accent));font-size:10px;font-weight:700;padding:2px 8px;border-radius:99px;margin-top:5px}
.pc-menu{display:flex;gap:6px;flex-shrink:0}
.ico-btn{width:34px;height:34px;border-radius:9px;background:var(--surface2);
  border:1px solid var(--border);color:var(--text2);font-size:14px;
  display:flex;align-items:center;justify-content:center;cursor:pointer}
.pc-body{padding:0 16px 12px}
.p-stats-r{display:flex;gap:16px;margin-bottom:10px}
.p-stat .v{font-size:20px;font-weight:700;color:var(--text)}
.p-stat .l{font-size:11px;color:var(--text2)}
.dchips{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.dchip{padding:5px 10px;border-radius:7px;font-size:11px;font-weight:600;
  background:var(--surface2);border:1px solid var(--border);color:var(--text2)}
.pc-foot{display:flex;gap:8px;padding:0 16px 16px}
.p-act-btn{flex:1;padding:10px;border-radius:10px;
  border:1.5px solid color-mix(in srgb,var(--plan-c,var(--accent)) 40%,transparent);
  background:color-mix(in srgb,var(--plan-c,var(--accent)) 10%,transparent);
  color:var(--plan-c,var(--accent));font-size:13px;font-weight:700;cursor:pointer}
.p-open-btn{padding:10px 16px;border-radius:10px;background:var(--surface2);
  border:1px solid var(--border);color:var(--text);font-size:13px;font-weight:600;cursor:pointer}

/* ── Plan detail ── */
.plan-det{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;margin-bottom:12px}
.pd-head{padding:16px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--border);
  background:linear-gradient(135deg,color-mix(in srgb,var(--plan-c,var(--accent)) 12%,transparent),transparent)}
.pd-ico{width:46px;height:46px;border-radius:13px;display:flex;align-items:center;justify-content:center;
  font-size:22px;background:color-mix(in srgb,var(--plan-c,var(--accent)) 18%,var(--surface2));flex-shrink:0}
.pd-info{flex:1;min-width:0}
.pd-name{font-size:17px;font-weight:800}
.pd-meta{font-size:12px;color:var(--text2);margin-top:2px}

/* ── Day rows ── */
.day-row{border-bottom:1px solid var(--border)}
.day-row:last-child{border-bottom:none}
.dr-head{display:flex;align-items:center;gap:10px;padding:13px 16px;cursor:pointer}
.dr-ico{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;
  font-size:16px;background:color-mix(in srgb,var(--plan-c,var(--accent)) 15%,var(--surface2));flex-shrink:0}
.dr-info{flex:1;min-width:0}
.dr-name{font-weight:700;font-size:14px}
.dr-meta{font-size:11px;color:var(--text2);margin-top:1px}
.dr-right{display:flex;align-items:center;gap:6px;flex-shrink:0}
.dr-today-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0}
.dr-chev{color:var(--text2);font-size:16px;transition:transform .2s}
.day-row.open .dr-chev{transform:rotate(90deg)}
.dr-body{display:none;padding:0 16px 14px}
.day-row.open .dr-body{display:block}

/* ── Exercise rows in plan ── */
.ex-row{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);
  border-radius:10px;margin-bottom:6px;border:1px solid var(--border)}
.ex-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ex-dot.s{background:var(--coral)}.ex-dot.c{background:var(--teal)}
.ex-info{flex:1;min-width:0}
.ex-name2{font-size:13px;font-weight:600}
.ex-det{font-size:11px;color:var(--text2);margin-top:1px}
.ex-btns{display:flex;gap:4px;flex-shrink:0}
.ex-b{width:30px;height:30px;border-radius:7px;background:none;border:none;
  color:var(--text2);font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.log-day-btn{width:100%;padding:10px;border-radius:10px;
  border:1.5px solid color-mix(in srgb,var(--plan-c,var(--accent)) 35%,transparent);
  background:color-mix(in srgb,var(--plan-c,var(--accent)) 10%,transparent);
  color:var(--plan-c,var(--accent));font-size:13px;font-weight:700;cursor:pointer;margin-bottom:10px}
.add-ex-btn,.add-day-btn{width:100%;padding:10px;border-radius:10px;
  border:1.5px dashed var(--border);background:none;color:var(--text2);
  font-size:13px;font-weight:600;cursor:pointer}
.add-day-btn{margin:0 16px 16px;width:calc(100% - 32px)}

/* ── Schedule badge on day ── */
.sched-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px}
.sched-tag{padding:2px 7px;border-radius:5px;font-size:10px;font-weight:700;
  background:color-mix(in srgb,var(--plan-c,var(--accent)) 18%,transparent);
  color:var(--plan-c,var(--accent));border:1px solid color-mix(in srgb,var(--plan-c,var(--accent)) 30%,transparent)}

/* ── Rewards ── */
.lv-hero{background:var(--yellow-light);border:1px solid var(--yellow-deep);
  border-radius:var(--radius-feature);padding:24px;text-align:center;margin-bottom:12px;position:relative;overflow:hidden;box-shadow:var(--shadow-md)}
.lv-hero::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;
  background:radial-gradient(circle,rgba(255,208,47,.35),transparent 70%);border-radius:50%;pointer-events:none}
.lv-hero::after{content:'FINISH HARD';position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);
  font-size:42px;font-weight:700;color:rgba(116,96,25,.07);letter-spacing:2px;white-space:nowrap;pointer-events:none}
.fh-brand{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--yellow-dark);margin-bottom:6px}
.lh-n{font-size:64px;font-weight:700;color:var(--text);line-height:1}
.lh-t{font-size:18px;font-weight:700;margin-top:4px;letter-spacing:.5px;color:var(--text)}
.lh-s{font-size:13px;color:var(--text2);margin-top:3px}
.lh-xp{font-size:22px;font-weight:600;color:var(--yellow-dark);margin-top:10px;background:var(--yellow);padding:6px 16px;border-radius:var(--radius-pill);display:inline-block}
.badge-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.badge{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);
  padding:14px 10px;text-align:center;box-shadow:var(--shadow-sm)}
.badge.unlocked{border-color:var(--yellow-deep);background:var(--yellow-light)}
.badge-ico{font-size:28px;margin-bottom:6px}
.badge-n{font-size:11px;font-weight:700}
.badge-d{font-size:10px;color:var(--text2);margin-top:2px}
.badge.locked .badge-ico{filter:grayscale(1) opacity(.3)}
.badge.locked .badge-n{color:var(--text2)}

/* ── Passes ── */
.passes-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:8px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.passes-scroll::-webkit-scrollbar{display:none}
.pass-card{flex-shrink:0;width:150px;border-radius:14px;padding:14px 12px;position:relative;overflow:hidden;cursor:default}
.pass-card::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);
  width:12px;height:12px;border-radius:50%;background:var(--bg);margin-left:-6px}
.pass-card::after{content:'';position:absolute;right:0;top:50%;transform:translateY(-50%);
  width:12px;height:12px;border-radius:50%;background:var(--bg);margin-right:-6px}
.pass-ico{font-size:28px;margin-bottom:6px}
.pass-name{font-size:12px;font-weight:800;line-height:1.2;margin-bottom:4px}
.pass-count{font-size:22px;font-weight:900;line-height:1}
.pass-avail{font-size:10px;opacity:.8;margin-top:2px}
.pass-use{margin-top:8px;font-size:11px;font-weight:700;padding:5px 10px;border-radius:20px;
  border:none;cursor:pointer;background:rgba(0,0,0,.25);color:#fff;width:100%}
.pass-use:disabled{opacity:.4;cursor:not-allowed}
.pass-earn{font-size:10px;opacity:.65;margin-top:6px}
.pass-used-overlay{position:absolute;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:center;
  justify-content:center;font-size:28px;border-radius:14px}

/* ── Real-life rewards ── */
.rr-card{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);
  padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:12px;box-shadow:var(--shadow-sm)}
.rr-card.unlocked{border-color:var(--green);background:var(--teal-light)}
.rr-card.claimed{border-color:var(--border-strong);background:var(--surface);opacity:.65}
.rr-ico{font-size:30px;flex-shrink:0;width:46px;height:46px;display:flex;align-items:center;justify-content:center;
  background:var(--surface2);border-radius:12px}
.rr-info{flex:1;min-width:0}
.rr-name{font-size:14px;font-weight:700}
.rr-desc{font-size:12px;color:var(--text2);margin-top:2px}
.rr-prog{font-size:11px;color:var(--yellow-dark);margin-top:4px;font-weight:600}
.rr-claim{font-size:12px;font-weight:600;background:var(--text);
  color:#fff;border:none;border-radius:var(--radius-pill);padding:7px 14px;cursor:pointer;flex-shrink:0;white-space:nowrap}
.rr-done{font-size:12px;font-weight:600;color:var(--green);flex-shrink:0}
.rr-locked-ico{font-size:18px;flex-shrink:0;color:var(--text2)}

/* ── Color/icon pickers ── */
.color-row{display:flex;gap:9px;flex-wrap:wrap}
.c-sw{width:32px;height:32px;border-radius:9px;cursor:pointer;
  border:3px solid transparent;transition:all .15s;flex-shrink:0}
.c-sw.sel{border-color:#fff;transform:scale(1.15)}
.icon-row{display:flex;gap:7px;flex-wrap:wrap}
.ic-p{width:40px;height:40px;border-radius:10px;background:var(--surface2);
  border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;
  font-size:20px;cursor:pointer}
.ic-p.sel{border-color:var(--yellow-deep);background:var(--yellow-light)}

/* ── Toast ── */
.toast{position:fixed;bottom:calc(var(--nav-h) + var(--safe-b) + 12px);left:50%;
  transform:translateX(-50%) translateY(20px);background:#18181B;color:#fff;
  border-radius:99px;padding:10px 20px;
  font-size:13px;font-weight:600;z-index:200;opacity:0;pointer-events:none;
  transition:all .3s cubic-bezier(.34,1.56,.64,1);box-shadow:var(--shadow-xl);white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── GCal row ── */
.gcal-r{display:flex;align-items:center;gap:12px;background:var(--surface);
  border:1px dashed var(--border);border-radius:var(--radius);padding:14px;margin-top:8px}

/* ── TDEE card ── */
.tdee-card{background:var(--surface);
  border:1px solid var(--border-soft);border-radius:var(--radius);padding:14px;margin-bottom:12px;box-shadow:var(--shadow-sm)}
.tdee-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.tdee-title{font-size:13px;font-weight:700;color:var(--text)}
.tdee-edit{font-size:11px;color:var(--text2);background:none;border:1px solid var(--border-soft);border-radius:var(--radius-pill);cursor:pointer;padding:3px 10px}
.tdee-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.tdee-cell{background:var(--surface2);border-radius:10px;padding:10px 12px}
.tdee-val{font-size:22px;font-weight:800;line-height:1}
.tdee-lbl{font-size:11px;color:var(--text2);margin-top:3px}
.tdee-sub{font-size:10px;color:var(--text2);margin-top:2px;opacity:.75}
.tdee-setup{text-align:center;padding:10px 0;color:var(--text2);font-size:13px}
.tdee-setup button{margin-top:8px;display:block;margin-left:auto;margin-right:auto}

/* ── PR badge ── */
.pr-badge{display:inline-flex;align-items:center;gap:4px;background:var(--yellow);
  border:none;color:var(--yellow-dark);font-size:10px;font-weight:700;
  padding:2px 8px;border-radius:var(--radius-pill);margin-left:6px}

/* ── Nutrition card ── */
.nut-card{background:var(--bg);border:1px solid var(--border-soft);border-radius:var(--radius);
  margin-bottom:12px;box-shadow:var(--shadow-md);overflow:hidden}
.nut-hdr{padding:14px 16px 10px;display:flex;align-items:center;justify-content:space-between}
.nut-title{font-size:15px;font-weight:700}
.nut-total{font-size:13px;color:var(--text2)}
.nut-total strong{color:var(--text);font-weight:700}
.nut-bar-wrap{padding:0 16px 12px}
.nut-bar-bg{height:6px;background:var(--border-soft);border-radius:99px;overflow:hidden}
.nut-bar-fill{height:100%;background:var(--yellow);border-radius:99px;transition:width .5s;max-width:100%}
.nut-bar-fill.over{background:var(--coral)}
.meal-row{border-top:1px solid var(--border-soft)}
.meal-hdr{display:flex;align-items:center;gap:10px;padding:11px 16px;cursor:pointer;user-select:none}
.meal-ico{font-size:18px;width:28px;text-align:center;flex-shrink:0}
.meal-name{font-size:14px;font-weight:600;flex:1}
.meal-cal{font-size:12px;color:var(--text2);font-weight:500;flex-shrink:0}
.meal-add{width:28px;height:28px;border-radius:var(--radius-pill);background:var(--text);color:#fff;
  border:none;font-size:16px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;flex-shrink:0;line-height:1}
.meal-chev{color:var(--text3);font-size:13px;flex-shrink:0;transition:transform .2s}
.meal-row.open .meal-chev{transform:rotate(90deg)}
.meal-body{display:none;padding:0 16px 10px}
.meal-row.open .meal-body{display:block}
.food-item{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border-soft)}
.food-item:last-child{border-bottom:none}
.food-name{font-size:13px;flex:1;color:var(--text)}
.food-cal{font-size:12px;font-weight:600;color:var(--text2);flex-shrink:0}
.food-del{background:none;border:none;color:var(--text3);font-size:15px;padding:2px 4px;cursor:pointer;flex-shrink:0}
.meal-empty{font-size:12px;color:var(--text3);padding:6px 0 2px;font-style:italic}
.nut-date-nav{display:flex;align-items:center;gap:8px;padding:0 16px 10px}
.nut-date-btn{width:30px;height:30px;border-radius:var(--radius-pill);background:var(--surface);
  border:1px solid var(--border-soft);color:var(--text);font-size:16px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nut-date-lbl{flex:1;text-align:center;font-size:13px;font-weight:600;color:var(--text)}
.nut-date-today{font-size:11px;padding:3px 10px;border-radius:var(--radius-pill);
  background:var(--yellow);border:none;color:var(--yellow-dark);font-weight:600;cursor:pointer;flex-shrink:0}
/* Food in calendar */
.cal-food-section{margin-top:12px}
.cal-food-item{display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--bg);
  border:1px solid var(--border-soft);border-radius:10px;margin-bottom:6px}
.cal-food-ico{font-size:16px;flex-shrink:0}
.cal-food-info{flex:1;min-width:0}
.cal-food-name{font-size:13px;font-weight:500}
.cal-food-meta{font-size:11px;color:var(--text2);margin-top:1px}

/* ── Autocomplete suggestion ── */
.repeat-bar{display:flex;gap:8px;overflow-x:auto;margin-bottom:12px;padding-bottom:2px}
.repeat-bar::-webkit-scrollbar{display:none}
.rpill{padding:7px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);
  font-size:12px;font-weight:600;color:var(--text2);white-space:nowrap;cursor:pointer;flex-shrink:0}
.rpill:active{background:var(--border)}

/* ── Exercise Library ── */
.lib-search-row{display:flex;gap:8px;margin-bottom:10px}
.lib-search-row .fi{flex:1}
.lib-filters{display:flex;gap:6px;overflow-x:auto;padding-bottom:4px;margin-bottom:10px}
.lib-filters::-webkit-scrollbar{display:none}
.lf-chip{padding:6px 12px;border-radius:var(--radius-pill);font-size:12px;font-weight:500;white-space:nowrap;
  cursor:pointer;border:1px solid var(--border-soft);background:var(--surface);color:var(--text2);flex-shrink:0;transition:all .15s}
.lf-chip.on{background:var(--yellow-light);border-color:var(--yellow-deep);color:var(--yellow-dark)}
.lf-chip.muscle.on{background:var(--teal-light);border-color:var(--teal);color:#0a756d}
.lf-chip.equip.on{background:var(--orange-light);border-color:#ffa852;color:#7a4010}
.lf-chip.diff.on{background:var(--rose);border-color:#f0b0c8;color:#8a0040}
.lib-cards{display:flex;flex-direction:column;gap:8px}
.lib-card{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:13px 14px}
.lc-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:8px}
.lc-ico{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0}
.lc-ico.s{background:var(--rose)}.lc-ico.c{background:var(--teal-light)}
.lc-ico.f{background:var(--teal-light)}.lc-ico.w{background:var(--yellow-light)}
.lc-info{flex:1;min-width:0}
.lc-name{font-size:14px;font-weight:700;line-height:1.3}
.lc-type{font-size:11px;color:var(--text2);margin-top:2px}
.lc-diff{font-size:11px;font-weight:700;padding:2px 7px;border-radius:5px;flex-shrink:0}
.diff-1{background:var(--teal-light);color:#0a756d;font-weight:600}
.diff-2{background:var(--yellow-light);color:var(--yellow-dark);font-weight:600}
.diff-3{background:var(--coral-light);color:var(--coral-dark);font-weight:600}
.lc-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px}
.lc-tag{padding:3px 8px;border-radius:5px;font-size:10px;font-weight:600}
.lc-tag.muscle{background:rgba(74,222,128,.1);color:#4ade80;border:1px solid rgba(74,222,128,.2)}
.lc-tag.equip{background:rgba(251,146,60,.1);color:#fb923c;border:1px solid rgba(251,146,60,.2)}
.lc-btns{display:flex;gap:7px}
.lc-tip{font-size:11px;color:var(--text2);margin-bottom:6px;font-style:italic;line-height:1.4}
.lib-hdr-btn{width:38px;height:38px;border-radius:10px;background:var(--surface2);
  border:1px solid var(--border);color:var(--text);font-size:18px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.lib-sub-tabs{display:flex;gap:0;background:var(--surface2);border-radius:10px;
  padding:3px;border:1px solid var(--border);margin-bottom:12px}
.lib-sub-tab{flex:1;padding:8px;border-radius:8px;border:none;background:none;
  color:var(--text2);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;text-align:center}
.lib-sub-tab.on{background:var(--text);color:#fff;font-weight:700}
.lib-count{font-size:12px;color:var(--text2);margin-bottom:8px;text-align:right}

/* Progressive overload hint */
.po-hint{background:var(--yellow-light);border:1px solid var(--yellow-deep);border-radius:12px;
  padding:10px 12px;margin-bottom:12px;font-size:12px;line-height:1.5;display:none}
.po-hint.show{display:block;animation:slideUp .2s}
.po-hint .po-last{color:var(--text2)}
.po-hint .po-last b{color:var(--text)}
.po-row{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:5px}
.po-sug{font-weight:700;color:var(--yellow-dark)}
.po-apply{background:var(--text);color:#fff;border:none;border-radius:99px;padding:5px 13px;font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0}
.po-pr{display:inline-block;background:var(--yellow);color:var(--yellow-dark);font-size:10px;font-weight:800;padding:1px 7px;border-radius:99px;margin-left:6px}

/* Rest Timer */
.rest-fab{position:fixed;left:20px;bottom:calc(var(--nav-h) + var(--safe-b) + 14px);
  width:56px;height:56px;border-radius:var(--radius-pill);background:var(--teal);border:none;
  color:#fff;font-size:22px;display:flex;align-items:center;justify-content:center;
  box-shadow:var(--shadow-lg);cursor:pointer;z-index:30;transition:all .15s}
.rest-fab:active{transform:scale(.93)}
.rest-panel{position:fixed;left:50%;transform:translateX(-50%) translateY(20px);
  bottom:calc(var(--nav-h) + var(--safe-b) + 16px);width:min(340px,calc(100% - 32px));
  background:var(--text);color:#fff;border-radius:20px;padding:16px 18px 18px;
  box-shadow:var(--shadow-xl);z-index:120;opacity:0;pointer-events:none;transition:all .25s cubic-bezier(.34,1.56,.64,1)}
.rest-panel.show{opacity:1;pointer-events:all;transform:translateX(-50%) translateY(0)}
.rest-panel.done{background:var(--green)}
.rt-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.rt-ttl{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;opacity:.85}
.rt-x{background:none;border:none;color:#fff;font-size:18px;cursor:pointer;opacity:.7;padding:2px 6px}
.rt-time{font-size:52px;font-weight:800;text-align:center;line-height:1;font-variant-numeric:tabular-nums;letter-spacing:1px}
.rt-bar{height:5px;background:rgba(255,255,255,.2);border-radius:99px;overflow:hidden;margin:12px 0}
.rt-bar-fill{height:100%;background:var(--yellow);border-radius:99px;transition:width 1s linear}
.rt-presets{display:flex;gap:7px;margin-bottom:10px}
.rt-preset{flex:1;padding:9px 0;border-radius:10px;border:1px solid rgba(255,255,255,.25);
  background:rgba(255,255,255,.08);color:#fff;font-size:13px;font-weight:700;cursor:pointer}
.rt-preset.on{background:var(--yellow);color:var(--text);border-color:var(--yellow)}
.rt-ctrls{display:flex;gap:8px}
.rt-btn{flex:1;padding:11px 0;border-radius:12px;border:none;font-size:14px;font-weight:700;cursor:pointer}
.rt-btn.pri{background:var(--yellow);color:var(--text)}
.rt-btn.sec{background:rgba(255,255,255,.14);color:#fff}

/* Ask Claude */
.ask-claude{display:inline-flex;align-items:center;gap:6px;background:#da7756;color:#fff;
  border:none;border-radius:var(--radius-pill);padding:8px 16px;font-size:13px;font-weight:700;
  cursor:pointer;text-decoration:none;box-shadow:var(--shadow-sm)}
.ask-claude:active{transform:scale(.97)}
.ask-claude.blk{width:100%;justify-content:center;padding:12px}
.ask-claude.mini{padding:5px 11px;font-size:12px}
</style>
