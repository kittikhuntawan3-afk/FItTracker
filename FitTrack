function earnedPasses(p){
  const streak=calcStreak(workouts);
  const metric=p.metric==='xp'?totalXP(workouts):p.metric==='streak'?streak:workouts.length;
  return Math.floor(metric/p.earnEvery);
}
function usePass(id){
  const p=PASSES.find(x=>x.id===id);
  if(!p)return;
  const earned=earnedPasses(p);
  const used=passesUsed[id]||0;
  if(used>=earned){toast('⚠️ No passes available yet');return;}
  passesUsed[id]=(used+1);
  savePasses();renderRewards();
  toast('🎉 Pass used! Enjoy — you earned it!');
}
function renderPasses(){
  const streak=calcStreak(workouts);
  document.getElementById('passes-list').innerHTML=PASSES.map(p=>{
    const earned=earnedPasses(p);
    const used=passesUsed[p.id]||0;
    const avail=Math.max(0,earned-used);
    const canUse=avail>0;
    return `<div class="pass-card" style="background:${p.bg};border:1.5px solid ${p.color}40">
      <div class="pass-ico">${p.ico}</div>
