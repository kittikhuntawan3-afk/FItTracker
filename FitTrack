function nutPrevDay(){
  const d=new Date(_nutDate);d.setDate(d.getDate()-1);
  _nutDate=d.toISOString().split('T')[0];renderNutrition();
}
function nutNextDay(){
  const d=new Date(_nutDate);d.setDate(d.getDate()+1);
  const next=d.toISOString().split('T')[0];
  if(next>today())return; // don't go into future
  _nutDate=next;renderNutrition();
