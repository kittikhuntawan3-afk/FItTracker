  {id:'dessert',    ico:'🍰', name:'Dessert Pass',       desc:'Full dessert. No portion control today.',       color:'#ec4899', bg:'rgba(236,72,153,.18)',  earnEvery:15, metric:'workouts', label:'per 15 workouts'},
  {id:'game-night', ico:'🎮', name:'Buy New Game Pass',   desc:'Pick up that game you\'ve been eyeing. You earned it.',   color:'#06b6d4', bg:'rgba(6,182,212,.18)',   earnEvery:20, metric:'workouts', label:'per 20 workouts'},
];

// ═══════════ MATH ═══════════
function totalXP(ws){return ws.reduce((s,w)=>s+(w.xp||0),0)}
function calcStreak(ws){
  if(!ws.length)return 0;
  const dates=[...new Set(ws.map(w=>w.date))].sort().reverse();
  const td=today();let n=0,cur=new Date(td);
  for(let i=0;i<365;i++){
    const d=cur.toISOString().split('T')[0];
    if(dates.includes(d)){n++;cur.setDate(cur.getDate()-1);}
    else if(i===0)cur.setDate(cur.getDate()-1);else break;
  }
  return n;
}
function balanced(ws){
  const wks={};
  ws.forEach(w=>{
    const d=new Date(w.date),dow=d.getDay()||7; // Sun=7,Mon=1..Sat=6
    const m=new Date(d);m.setDate(d.getDate()-dow+1);
    const k=m.toISOString().split('T')[0];if(!wks[k])wks[k]=new Set();wks[k].add(w.type);
  });
  return Object.values(wks).some(s=>s.has('strength')&&s.has('cardio'));
}
function lvData(xp){
  let cur=LEVELS[0],next=LEVELS[1];
  for(let i=LEVELS.length-1;i>=0;i--){if(xp>=LEVELS[i].xp){cur=LEVELS[i];next=LEVELS[i+1]||null;break;}}
  const xi=xp-cur.xp,xn=next?next.xp-cur.xp:1;
  return{level:cur.level,title:cur.title,xi,xn,pct:Math.min(100,Math.round(xi/xn*100)),xp,next};
}
function today(){return new Date().toISOString().split('T')[0]}
function todayDowKey(){return WDAY_KEYS[new Date().getDay()===0?6:new Date().getDay()-1]}
function save(){localStorage.setItem('ft_workouts',JSON.stringify(workouts));scheduleSyncToGitHub()}
function savePlans(){localStorage.setItem('ft_plans',JSON.stringify(plans));scheduleSyncToGitHub()}
function saveWeights(){localStorage.setItem('ft_weights',JSON.stringify(weights));scheduleSyncToGitHub()}
function saveFood(){localStorage.setItem('ft_food',JSON.stringify(foods));scheduleSyncToGitHub()}
function saveProfile(){localStorage.setItem('ft_profile',JSON.stringify(profile));scheduleSyncToGitHub()}
function saveClaimed(){localStorage.setItem('ft_claimed',JSON.stringify([...claimedRR]));scheduleSyncToGitHub()}
function savePasses(){localStorage.setItem('ft_passes',JSON.stringify(passesUsed));scheduleSyncToGitHub()}

// ── GitHub Sync ──────────────────────────────────────────
function ghReady(){return !!(ghConfig.token&&ghConfig.owner&&ghConfig.repo)}

function setSyncBadge(state,label){
  const b=document.getElementById('sync-badge');
  const d=document.getElementById('sync-status-detail');
  if(!b)return;
  b.className='sync-badge '+state;
  const icons={idle:'☁️',syncing:'🔄',ok:'✅',err:'❌'};
  b.textContent=(icons[state]||'☁️')+' '+(label||'--');
  if(d)d.textContent=label||'';
}

function scheduleSyncToGitHub(){
  if(!ghReady())return;
  clearTimeout(_syncTimer);
  setSyncBadge('syncing','saving…');
  _syncTimer=setTimeout(()=>syncToGitHub(false),2000); // debounce 2s
}

async function syncToGitHub(manual=false){
  if(!ghReady()){if(manual){toast('⚙️ Set up GitHub credentials first');openSheet('s-github');}return;}
  setSyncBadge('syncing','pushing…');
  const data={
    workouts,plans,weights,foods,profile,
    claimed:[...claimedRR],passes:passesUsed,
    lastSync:new Date().toISOString(),v:1
  };
  const path=ghConfig.path||'data.json';
  const branch=ghConfig.branch||'main';
  const apiURL=`https://api.github.com/repos/${ghConfig.owner}/${ghConfig.repo}/contents/${path}`;
  const headers={'Authorization':'token '+ghConfig.token,'Content-Type':'application/json'};
  try{
    let sha=null;
    const check=await fetch(apiURL,{headers});
    if(check.ok){const j=await check.json();sha=j.sha;}
    const body={message:'FitTracker sync '+new Date().toLocaleTimeString(),
      content:btoa(unescape(encodeURIComponent(JSON.stringify(data,null,2)))),branch};
    if(sha)body.sha=sha;
    const r=await fetch(apiURL,{method:'PUT',headers,body:JSON.stringify(body)});
    if(r.ok){
      const ts=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
      setSyncBadge('ok','synced '+ts);
      localStorage.setItem('ft_lastsync',ts);
      if(manual)toast('✅ Pushed to GitHub!');
    } else {
      const err=await r.json();
      setSyncBadge('err','push failed');
      if(manual)toast('❌ GitHub error: '+(err.message||r.status));
    }
  }catch(e){
    setSyncBadge('err','offline');
    if(manual)toast('❌ Network error: '+e.message);
  }
}

async function pullFromGitHub(manual=false){
  if(!ghReady()){if(manual){toast('⚙️ Set up GitHub credentials first');openSheet('s-github');}return;}
  setSyncBadge('syncing','pulling…');
  const path=ghConfig.path||'data.json';
  const branch=ghConfig.branch||'main';
  const rawURL=`https://raw.githubusercontent.com/${ghConfig.owner}/${ghConfig.repo}/${branch}/${path}?t=${Date.now()}`;
  try{
    const r=await fetch(rawURL);
    if(!r.ok){setSyncBadge('err','pull failed');if(manual)toast('❌ File not found in repo yet');return;}
    const data=await r.json();
    if(data.workouts){workouts=data.workouts;localStorage.setItem('ft_workouts',JSON.stringify(workouts));}
    if(data.plans){plans=data.plans;localStorage.setItem('ft_plans',JSON.stringify(plans));}
    if(data.weights){weights=data.weights;localStorage.setItem('ft_weights',JSON.stringify(weights));}
    if(data.foods){foods=data.foods;localStorage.setItem('ft_food',JSON.stringify(foods));}
    if(data.profile){profile=data.profile;localStorage.setItem('ft_profile',JSON.stringify(profile));}
    if(data.claimed){claimedRR=new Set(data.claimed);localStorage.setItem('ft_claimed',JSON.stringify(data.claimed));}
    if(data.passes){passesUsed=data.passes;localStorage.setItem('ft_passes',JSON.stringify(passesUsed));}
    refreshAll();renderRewards();
    const ts=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    setSyncBadge('ok','synced '+ts);
    if(manual)toast('⬇️ Pulled from GitHub!');
  }catch(e){
    setSyncBadge('err','offline');
    if(manual)toast('❌ Pull failed: '+e.message);
  }
}

