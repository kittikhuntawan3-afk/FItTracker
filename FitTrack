function initCal(){const n=new Date();calY=n.getFullYear();calM=n.getMonth();}
function getScheduledDays(dateStr){
  const d=new Date(dateStr),key=WDAY_KEYS[d.getDay()===0?6:d.getDay()-1];
  return plans.filter(p=>p.active).flatMap(p=>p.days.filter(day=>day.schedule?.includes(key)).map(day=>({plan:p,day})));
}
const MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
function renderCal(){
  document.getElementById('cal-month-lbl').textContent=`${MONTHS[calM]} ${calY}`;
  document.getElementById('cal-dn').innerHTML=['S','M','T','W','T','F','S'].map(d=>`<div class="cdn">${d}</div>`).join('');
  const fd=new Date(calY,calM,1).getDay(),dim=new Date(calY,calM+1,0).getDate(),td=today();
  let html='';
  for(let i=0;i<fd;i++)html+='<div class="cday empty"></div>';
  for(let d=1;d<=dim;d++){
    const ds=`${calY}-${String(calM+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dws=workouts.filter(w=>w.date===ds);
    const hasS=dws.some(w=>w.type==='strength'),hasC=dws.some(w=>w.type==='cardio');
    const isT=ds===td,isSel=ds===calSel;
    const hasPlan=getScheduledDays(ds).length>0;
    let cls=`cday${isT?' today':''}${dws.length?' '+(hasS&&hasC?'has-b':hasS?'has-s':'has-c'):''}${isSel?' sel':''}`;
    let dot=hasS&&hasC?`<div class="cday-dot" style="background:var(--accent)"></div>`:hasS?`<div class="cday-dot" style="background:var(--accent2)"></div>`:hasC?`<div class="cday-dot" style="background:var(--blue)"></div>`:'';
    let planDot=hasPlan&&!dws.length?`<div class="plan-dot"></div>`:'';
    html+=`<div class="${cls}" onclick="selectCalDay('${ds}')" style="${isSel?'outline:2px solid var(--accent);outline-offset:1px;':''}">${d}${dot}${planDot}</div>`;
  }
  document.getElementById('cal-days').innerHTML=html;
}
function calDayGcalURL(ds, dws){
  // Build a single GCal event for all workouts on a day
  const d=ds.replace(/-/g,'');
  const next=new Date(ds);next.setDate(next.getDate()+1);
  const d2=next.toISOString().split('T')[0].replace(/-/g,'');
  const totalXp=dws.reduce((s,w)=>s+w.xp,0);
  const title=encodeURIComponent(`🏋️ Workout – ${ds}`);
  const lines=dws.map(w=>{
    const isS=w.type==='strength';
    const name=isS?w.exercise:w.activity;
    const meta=isS?[w.sets&&`${w.sets}×${w.reps}`,w.weight&&`${w.weight}kg`].filter(Boolean).join(' ')
                  :[w.duration&&`${w.duration}min`,w.distance&&`${w.distance}km`].filter(Boolean).join(' ');
    return `${isS?'💪':'🏃'} ${name}${meta?' – '+meta:''}`;
  });
  lines.push(`Total: +${totalXp}XP`);
  const det=encodeURIComponent(lines.join('\n'));
  return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${d}/${d2}&details=${det}`;
}
function selectCalDay(ds){
  calSel=ds;renderCal();
  const dws=workouts.filter(w=>w.date===ds);
  const scheduled=getScheduledDays(ds);
  const dFoods=foodsForDate(ds);
  document.getElementById('cal-day-title').textContent=`${ds}`;
  // Show/hide day-level GCal button
  const gcalBtn=document.getElementById('cal-gcal-btn');
  if(dws.length){gcalBtn.href=calDayGcalURL(ds,dws);gcalBtn.style.display='';}
  else{gcalBtn.style.display='none';}
  // Workouts
  let html=dws.length?dws.map(w=>wHTML(w,false)).join(''):'';
  if(scheduled.length){
    html+=`<div class="sec-title" style="margin-top:${dws.length?12:0}px">Planned</div>`;
    html+=scheduled.map(({plan,day})=>`<div class="wi" style="opacity:.85">
