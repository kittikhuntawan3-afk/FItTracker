  };
  saveProfile();closeSheet('s-tdee');renderHome();toast('✅ Profile saved!');
}
function renderTDEECard(){
  const wrap=document.getElementById('tdee-card-wrap');
  const t=calcTDEE(), pr=calcProtein();
  if(!t){
    wrap.innerHTML=`<div class="tdee-card"><div class="tdee-setup">
      <div>Set up your profile for TDEE & protein targets</div>
      <button class="btn btn-p btn-sm" onclick="openTDEESheet()">⚡ Set Up Profile</button>
    </div></div>`;
    return;
  }
  const goalLabel=profile.goal==='cut'?'Cut −300':profile.goal==='bulk'?'Bulk +300':'Maintain';
  const proteinColor=pr.workout?'var(--accent2)':'var(--green)';
  const dayLabel=pr.workout?'🏋️ Workout day':'😴 Rest day';
  wrap.innerHTML=`<div class="tdee-card">
    <div class="tdee-top">
      <div class="tdee-title">⚡ Daily Targets</div>
