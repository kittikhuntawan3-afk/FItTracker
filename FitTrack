// Effort-based XP (replaces old flat XP={strength:30,cardio:25})
function calcXP(w){
  if(w.type==='strength'){
    const sets=Math.min(w.sets||0,6);
    const reps=+(w.reps)||0;
    const kg=w.weight||0;
    const base=25;
    const setBon=sets*4;                                    // 0–24
    const repBon=reps>=16?8:reps>=8?5:0;                   // 0, 5, or 8
    const wgtBon=kg>120?22:kg>80?16:kg>40?10:kg>0?5:0;     // 0, 5, 10, 16, 22
    return base+setBon+repBon+wgtBon;                       // range ~25–79
  } else {
    const dur=Math.min(w.duration||0,90);
    const dist=Math.min(w.distance||0,21);
    const base=20;
    const durBon=Math.round(dur*0.6);                       // 0–54
    const distBon=Math.round(dist*1.5);                     // 0–31
    return base+durBon+distBon;                             // range ~20–105
  }
}
