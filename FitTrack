  }
  if(!dws.length&&!scheduled.length)html='<div class="empty"><div class="ei">😴</div><div class="et">Rest day</div></div>';
  // Food section
  if(dFoods.length){
    const totalCal=dFoods.reduce((s,f)=>s+(f.cal||0),0);
    html+=`<div class="cal-food-section">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
        <div class="sec-title" style="margin:0">🍽 Food</div>
        <div style="font-size:12px;font-weight:600;color:var(--yellow-dark);background:var(--yellow-light);padding:2px 10px;border-radius:var(--radius-pill)">${totalCal.toLocaleString()} kcal</div>
      </div>`;
    MEALS.forEach(m=>{
      const mf=dFoods.filter(f=>f.meal===m.key);
      if(!mf.length)return;
      const mc=mf.reduce((s,f)=>s+(f.cal||0),0);
      html+=`<div class="cal-food-item">
        <div class="cal-food-ico">${m.icon}</div>
        <div class="cal-food-info">
          <div class="cal-food-name">${m.label}</div>
          <div class="cal-food-meta">${mf.map(f=>f.name).join(', ')}</div>
        </div>
        <div style="font-size:12px;font-weight:600;color:var(--text2);flex-shrink:0">${mc} kcal</div>
      </div>`;
    });
    // button to jump to that day's nutrition log
    if(ds<=today()){
      html+=`<button class="btn btn-s btn-blk btn-sm" style="margin-top:6px" onclick="nutGoToDate('${ds}');showPage('home')">📋 View Full Food Log</button>`;
    }
    html+=`</div>`;
  } else if(ds<=today()){
    html+=`<div class="cal-food-section">
      <div style="font-size:12px;color:var(--text3);padding:8px 0">No food logged — <button style="background:none;border:none;color:var(--blue);font-size:12px;cursor:pointer;padding:0;font-weight:600" onclick="nutGoToDate('${ds}');showPage('home')">Log now</button></div>
    </div>`;
  }
  document.getElementById('cal-day-list').innerHTML=html;
}
