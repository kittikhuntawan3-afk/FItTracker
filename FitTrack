function foodsForDate(d){return foods.filter(f=>f.date===d)}
function totalCalForDate(d){return foodsForDate(d).reduce((s,f)=>s+(f.cal||0),0)}
function totalProtForDate(d){return foodsForDate(d).reduce((s,f)=>s+(f.prot||0),0)}
// legacy helpers used elsewhere
function todayFoods(){return foodsForDate(_nutDate)}
