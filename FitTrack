  if(wType==='strength'){
    const ex=document.getElementById('wi-ex').value.trim();
    if(!ex){toast('⚠️ Enter exercise name');return;}
    const kg=+document.getElementById('wi-kg').value||0;
    const prevPR=getPersonalRecord(ex);
    isPR=kg>0&&(prevPR===null||kg>prevPR);
    w.exercise=ex;w.sets=+document.getElementById('wi-sets').value||0;
    w.reps=+document.getElementById('wi-reps').value||0;w.weight=kg;
  } else {
