// Patch rpill to use data attr instead of inline onclick
function buildRepeatBar(){
  const recents=[...workouts].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,8);
  const seen=new Set();
  const unique=recents.filter(w=>{
    const key=w.type==='strength'?w.exercise:w.activity;
    if(seen.has(key))return false;seen.add(key);return true;
  }).slice(0,5);
  const bar=document.getElementById('repeat-bar');
  if(!unique.length){bar.innerHTML='';return;}
  bar.innerHTML=`<span style="font-size:12px;color:var(--text2);padding-top:6px;flex-shrink:0">Repeat:</span>`+
    unique.map(w=>`<div class="rpill" data-prefill='${JSON.stringify(w).replace(/'/g,"&#39;")}'>${w.type==='strength'?w.exercise:w.activity}</div>`).join('');
}
