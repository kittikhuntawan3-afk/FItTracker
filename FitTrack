function nutGoToDate(ds){_nutDate=ds;renderNutrition();}

function renderNutrition(){
  const wrap=document.getElementById('nut-card-wrap');
  if(!wrap)return;
  const tdee=calcTDEE();
  const goal=tdee?tdee.target:2000;
  const dayFoods=foodsForDate(_nutDate);
  const eaten=dayFoods.reduce((s,f)=>s+(f.cal||0),0);
  const prot=dayFoods.reduce((s,f)=>s+(f.prot||0),0);
  const pct=Math.min(eaten/goal*100,100);
  const over=eaten>goal;
  const isToday=_nutDate===today();
  const dateLabel=isToday?'Today':new Date(_nutDate+'T12:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});

  let html=`<div class="nut-card">
    <div class="nut-hdr">
      <div class="nut-title">🍽 Food Log</div>
      <div class="nut-total"><strong>${eaten.toLocaleString()}</strong> / ${goal.toLocaleString()} kcal${prot?` · <strong>${prot}g</strong> P`:''}</div>
    </div>
    <div class="nut-date-nav">
      <button class="nut-date-btn" onclick="nutPrevDay()">‹</button>
      <div class="nut-date-lbl">${dateLabel}</div>
      ${!isToday?`<button class="nut-date-today" onclick="nutGoToDate('${today()}')">Today</button>`:''}
      <button class="nut-date-btn" onclick="nutNextDay()" ${isToday?'style="opacity:.3;pointer-events:none"':''}>›</button>
    </div>
    <div class="nut-bar-wrap">
      <div class="nut-bar-bg"><div class="nut-bar-fill${over?' over':''}" style="width:${pct}%"></div></div>
    </div>`;

  MEALS.forEach(m=>{
    const mFoods=dayFoods.filter(f=>f.meal===m.key);
    const mCal=mFoods.reduce((s,f)=>s+(f.cal||0),0);
    html+=`<div class="meal-row" id="mr-${m.key}">
      <div class="meal-hdr" onclick="toggleMeal('${m.key}')">
        <div class="meal-ico">${m.icon}</div>
