// ═══════════ CHARTS ═══════════
function svgWeeklyBars(container){
  const now=new Date();
  const weeks=[];
  for(let i=7;i>=0;i--){
    const d=new Date(now);d.setDate(now.getDate()-i*7);
    const wStart=new Date(d);wStart.setDate(d.getDate()-d.getDay());
    const wEnd=new Date(wStart);wEnd.setDate(wStart.getDate()+6);
    const label=wStart.toLocaleDateString('en',{month:'short',day:'numeric'});
    const wWs=workouts.filter(w=>{const wd=new Date(w.date);return wd>=wStart&&wd<=wEnd;});
    weeks.push({label,s:wWs.filter(w=>w.type==='strength').length,c:wWs.filter(w=>w.type==='cardio').length});
  }
  const maxVal=Math.max(...weeks.map(w=>w.s+w.c),1);
  const W=container.clientWidth||340,H=140,PAD=28,BAR_AREA=W-PAD*2;
  const bw=Math.floor(BAR_AREA/weeks.length)-4,gap=(BAR_AREA-bw*weeks.length)/(weeks.length-1)||0;
  let bars='',labels='';
  weeks.forEach((wk,i)=>{
    const x=PAD+i*(bw+gap);
    const totalH=Math.round(((wk.s+wk.c)/maxVal)*(H-30));
    const sH=Math.round((wk.s/(wk.s+wk.c||1))*totalH);
    const cH=totalH-sH;
    if(cH>0)bars+=`<rect x="${x}" y="${H-20-totalH}" width="${bw}" height="${cH}" rx="3" fill="#4262ff" opacity=".85"/>`;
    if(sH>0)bars+=`<rect x="${x}" y="${H-20-totalH+cH}" width="${bw}" height="${sH}" rx="3" fill="#ff9999" opacity=".85"/>`;
    if(totalH===0)bars+=`<rect x="${x}" y="${H-22}" width="${bw}" height="2" rx="1" fill="#e0e2e8"/>`;
    if(i%2===0)labels+=`<text x="${x+bw/2}" y="${H-4}" text-anchor="middle" class="chart-label">${wk.label.split(' ')[0]}</text>`;
  });
  container.innerHTML=`<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">${bars}${labels}</svg>`;
}

function svgWeightLine(container){
  const sorted=[...weights].sort((a,b)=>a.date.localeCompare(b.date)).slice(-20);
  if(sorted.length<2){
    container.innerHTML=sorted.length===1
      ?`<div style="text-align:center;padding:12px;font-size:14px;color:var(--blue);font-weight:700">${sorted[0].weight} kg on ${sorted[0].date}</div>`
      :`<div style="text-align:center;padding:12px;font-size:13px;color:var(--text2)">Log at least 2 entries to see chart</div>`;
    return;
  }
  const vals=sorted.map(e=>e.weight);
  const minV=Math.min(...vals),maxV=Math.max(...vals);
  const range=maxV-minV||1;
  const W=container.clientWidth||340,H=110,PAD=36;
  const pts=sorted.map((e,i)=>{
    const x=PAD+(i/(sorted.length-1))*(W-PAD*2);
    const y=10+(1-(e.weight-minV)/range)*(H-30);
    return{x,y,w:e.weight,d:e.date};
  });
  const path=pts.map((p,i)=>i===0?`M${p.x},${p.y}`:`L${p.x},${p.y}`).join(' ');
  const areaPath=`${pts.map((p,i)=>i===0?`M${p.x},${p.y}`:`L${p.x},${p.y}`).join(' ')} L${pts[pts.length-1].x},${H-12} L${pts[0].x},${H-12} Z`;
  let dotsSvg=pts.map(p=>`<circle cx="${p.x}" cy="${p.y}" r="3" fill="#4262ff"/>`).join('');
  let yLabels=`<text x="2" y="${14}" class="chart-label" fill="#4262ff">${maxV}kg</text><text x="2" y="${H-14}" class="chart-label" fill="#4262ff">${minV}kg</text>`;
  container.innerHTML=`<svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">
    <defs><linearGradient id="wg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#4262ff" stop-opacity=".25"/><stop offset="100%" stop-color="#4262ff" stop-opacity="0"/></linearGradient></defs>
    <path d="${areaPath}" fill="url(#wg)"/>
    <path d="${path}" class="chart-line" stroke="#4262ff"/>
    ${dotsSvg}${yLabels}
  </svg>`;
}

function renderTopExercises(container){
  const strength=workouts.filter(w=>w.type==='strength'&&w.exercise&&w.weight>0);
  const vol={};
  strength.forEach(w=>{
    const k=w.exercise;
    if(!vol[k])vol[k]={name:k,vol:0,count:0,maxW:0};
    vol[k].vol+=w.sets*w.reps*w.weight;
    vol[k].count++;
    if(w.weight>vol[k].maxW)vol[k].maxW=w.weight;
  });
  const top=Object.values(vol).sort((a,b)=>b.vol-a.vol).slice(0,5);
  if(!top.length){container.innerHTML='<div style="text-align:center;padding:12px;font-size:13px;color:var(--text2)">Log strength workouts to see volume stats</div>';return;}
  const maxVol=top[0].vol||1;
  container.innerHTML=top.map(e=>{
    const pr=getPersonalRecord(e.name);
    const pct=Math.round(e.vol/maxVol*100);
    return `<div style="margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:5px;align-items:center">
        <span style="font-weight:600">${e.name} ${pr?`<span class="pr-badge">PR ${pr}kg</span>`:''}</span>
        <span style="color:var(--text2);font-size:11px">${e.count} sessions</span>
      </div>
      <div class="sbar-bg"><div class="sbar-fill" style="width:${pct}%;background:linear-gradient(90deg,var(--accent),var(--accent2))"></div></div>
      <div style="font-size:11px;color:var(--text2);margin-top:3px">${Math.round(e.vol).toLocaleString()} kg total volume</div>
    </div>`;
  }).join('');
}

