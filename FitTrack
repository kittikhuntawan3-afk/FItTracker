const MUSCLES_ALL=[...new Set(EX_DB.flatMap(e=>e.muscles))].sort();
const EQUIPS_ALL=[...new Set(EX_DB.flatMap(e=>e.equip))].sort();
const DIFFS=['Easy','Medium','Hard'];

let libTab='all', libMuscles=new Set(), libEquips=new Set(), libDiffs=new Set();
let libCallbackFn=null; // if set, selecting exercise calls this instead of log sheet
let libCurrentResults=[]; // cached filtered results for index lookup

function openLibrary(callbackFn){
  libCallbackFn=callbackFn||null;
  buildLibFilters();renderLib();
  openSheet('s-lib');
  setTimeout(()=>document.getElementById('lib-q').focus(),300);
}
function openLibraryForWorkout(){
  openLibrary(function(e){
    document.getElementById('wi-ex').value=e.name;
    document.getElementById('wi-sets').value=e.sets||'';
    document.getElementById('wi-reps').value=e.reps||'';
    document.getElementById('wi-kg').value=e.kg||'';
    openSheet('s-workout');
  });
}
function openLibraryForExercise(){
  openLibrary(function(e){
    document.getElementById('se-name').value=e.name;
    document.getElementById('se-sets').value=e.sets||'';
    document.getElementById('se-reps').value=e.reps||'';
    document.getElementById('se-kg').value=e.kg||'';
    openSheet('s-ex');
  });
}

function buildLibFilters(){
  document.getElementById('lib-muscles').innerHTML=MUSCLES_ALL.map(m=>
    `<div class="lf-chip muscle ${libMuscles.has(m)?'on':''}" onclick="toggleLibFilter('muscle','${m}')">${m}</div>`).join('');
  document.getElementById('lib-equips').innerHTML=EQUIPS_ALL.map(e=>
    `<div class="lf-chip equip ${libEquips.has(e)?'on':''}" onclick="toggleLibFilter('equip','${e}')">${e}</div>`).join('');
  document.getElementById('lib-diffs').innerHTML=DIFFS.map((d,i)=>
    `<div class="lf-chip diff ${libDiffs.has(i+1)?'on':''}" onclick="toggleLibFilter('diff',${i+1})">${d}</div>`).join('');
}

function setLibTab(t){
  libTab=t;
  ['all','strength','cardio','flex'].forEach(x=>document.getElementById('lst-'+x).classList.toggle('on',x===t));
  renderLib();
}

function toggleLibFilter(kind,val){
  const set={muscle:libMuscles,equip:libEquips,diff:libDiffs}[kind];
  if(set.has(val))set.delete(val);else set.add(val);
  buildLibFilters();renderLib();
}

function clearLibFilters(){
  document.getElementById('lib-q').value='';
  libTab='all';libMuscles=new Set();libEquips=new Set();libDiffs=new Set();
  buildLibFilters();
  ['all','strength','cardio','flex'].forEach(x=>document.getElementById('lst-'+x).classList.toggle('on',x==='all'));
  renderLib();
}

function renderLib(){
  const q=document.getElementById('lib-q').value.trim().toLowerCase();
  let results=EX_DB.filter(e=>{
    if(libTab==='strength'&&e.type!=='strength')return false;
    if(libTab==='cardio'&&e.type!=='cardio')return false;
    if(libTab==='flex'&&e.type!=='flex'&&e.type!=='warmup')return false;
    if(q&&!e.name.toLowerCase().includes(q)&&!e.muscles.some(m=>m.toLowerCase().includes(q)))return false;
    if(libMuscles.size&&!e.muscles.some(m=>libMuscles.has(m)))return false;
    if(libEquips.size&&!e.equip.some(eq=>libEquips.has(eq)))return false;
    if(libDiffs.size&&!libDiffs.has(e.diff))return false;
    return true;
  });
  libCurrentResults=results;
  document.getElementById('lib-count').textContent=`${results.length} exercise${results.length!==1?'s':''}`;
  document.getElementById('lib-result-count').textContent=`${results.length} of ${EX_DB.length} exercises`;
  if(!results.length){
    document.getElementById('lib-cards').innerHTML='<div class="empty"><div class="ei">🔍</div><div class="et">No exercises match.<br>Try clearing some filters.</div></div>';
    return;
  }
  const typeIco={strength:'💪',cardio:'🏃',flex:'🧘',warmup:'🌡'};
  const typeClass={strength:'s',cardio:'c',flex:'f',warmup:'w'};
  const diffLabel=['','Easy','Medium','Hard'];
  document.getElementById('lib-cards').innerHTML=results.map((e,i)=>{
    const alreadyLogged=workouts.filter(w=>(w.exercise||w.activity)===e.name).length;
    const pr=e.type==='strength'&&e.kg?getPersonalRecord(e.name):'';
    const btnLabel=libCallbackFn?'➕ Use':'▶ Log Now';
    return `<div class="lib-card">
      <div class="lc-top">
        <div class="lc-ico ${typeClass[e.type]||'s'}">${typeIco[e.type]||'💪'}</div>
        <div class="lc-info">
          <div class="lc-name">${e.name}${pr?'<span class="pr-badge">PR '+pr+'kg</span>':''}</div>
          <div class="lc-type">${e.type==='strength'?'Strength':e.type==='cardio'?'Cardio':e.type==='flex'?'Flexibility':'Warm-up'} · ${e.equip.join(', ')}</div>
        </div>
        <span class="lc-diff diff-${e.diff}">${diffLabel[e.diff]}</span>
      </div>
      <div class="lc-tags">
        ${e.muscles.map(m=>'<span class="lc-tag muscle">'+m+'</span>').join('')}
        ${e.equip.map(eq=>'<span class="lc-tag equip">'+eq+'</span>').join('')}
      </div>
      ${e.tip?'<div class="lc-tip">💡 '+e.tip+'</div>':''}
      <div class="lc-btns">
        <button class="btn btn-p btn-sm" style="flex:1" onclick="selectLibExercise(${i})">${btnLabel}</button>
        ${alreadyLogged?'<span style="font-size:11px;color:var(--green);padding:8px 6px;font-weight:600">✓ '+alreadyLogged+'×</span>':''}
      </div>
    </div>`;
  }).join('');
}

function selectLibExercise(idx){
  const e=libCurrentResults[idx];
  if(!e)return;
  if(libCallbackFn){libCallbackFn(e);closeSheet('s-lib');return;}
  closeSheet('s-lib');
  setTimeout(()=>{
    if(e.type==='strength'){
      openWorkoutSheet('',{type:'strength',exercise:e.name,sets:e.sets||0,reps:e.reps||'',weight:e.kg||0});
    } else if(e.type==='cardio'){
      openWorkoutSheet('',{type:'cardio',activity:e.name,duration:e.duration||30,distance:0});
    } else {
      openWorkoutSheet('',{type:'strength',exercise:e.name,sets:e.sets||0,reps:e.reps||'',weight:0});
    }
  },250);
}


// ═══════════ PROGRESSIVE OVERLOAD ═══════════
function est1RM(weight,reps){ if(!weight)return 0; return Math.round(weight*(1+(reps||1)/30)); }
function lastSessionFor(name){
  const list=workouts.filter(w=>w.type==='strength'&&w.exercise&&w.exercise.toLowerCase()===name.toLowerCase());
  if(!list.length)return null;
  list.sort((a,b)=> b.date.localeCompare(a.date) || (b.id-a.id));
  return list[0];
}
let _poSuggest=null;
function updateOverloadHint(){
  const el=document.getElementById('po-hint'); if(!el)return;
  const name=(document.getElementById('wi-ex').value||'').trim();
  _poSuggest=null;
  if(name.length<2){el.classList.remove('show');el.innerHTML='';return;}
  const last=lastSessionFor(name);
  if(!last){el.classList.remove('show');el.innerHTML='';return;}
  const pr=getPersonalRecord(name);
  const kg=last.weight||0, reps=last.reps||0, sets=last.sets||0;
  const isPR=kg>0&&pr&&kg>=pr;
  let sKg=kg,sReps=reps;
  const TARGET=8;
  if(kg>0){ if(reps>=TARGET){sKg=kg+2.5;sReps=reps;} else {sKg=kg;sReps=reps+1;} }
  _poSuggest={sets:sets||3,reps:sReps,kg:sKg};
  const sugTxt = kg>0 ? `Try <b>${sKg}kg × ${sReps}</b>` : `Add a rep or a little weight`;
  el.innerHTML=`<div class="po-last">Last (${last.date}): <b>${sets}×${reps}${kg?` @ ${kg}kg`:''}</b>${isPR?'<span class="po-pr">PR</span>':''}</div>
    <div class="po-row"><span class="po-sug">⬆️ ${sugTxt}</span>${kg>0?'<button type="button" class="po-apply" onclick="applyOverload()">Use</button>':''}</div>`;
  el.classList.add('show');
}
function applyOverload(){
  if(!_poSuggest)return;
  document.getElementById('wi-sets').value=_poSuggest.sets;
  document.getElementById('wi-reps').value=_poSuggest.reps;
  document.getElementById('wi-kg').value=_poSuggest.kg;
  toast('🎯 Target loaded — go beat it!');
}

// ═══════════ REST TIMER ═══════════
let _rtRemain=90,_rtTotal=90,_rtPreset=90,_rtInt=null,_rtRunning=false;
function fmtT(s){const m=Math.floor(s/60),ss=s%60;return `${m}:${ss<10?'0':''}${ss}`;}
function toggleRestPanel(){const p=document.getElementById('rest-panel');p.classList.toggle('show');renderRest();}
function closeRest(){document.getElementById('rest-panel').classList.remove('show');}
function setRestPreset(sec){
  _rtPreset=sec;
  if(!_rtRunning){_rtTotal=sec;_rtRemain=sec;document.getElementById('rest-panel').classList.remove('done');}
  document.querySelectorAll('.rt-preset').forEach(b=>b.classList.toggle('on',+b.dataset.s===sec));
  renderRest();
}
function startRestTimer(sec,autoOpen){
  _rtTotal=sec||_rtPreset;_rtRemain=_rtTotal;_rtRunning=true;
  const p=document.getElementById('rest-panel');p.classList.remove('done');
  if(autoOpen)p.classList.add('show');
  document.querySelectorAll('.rt-preset').forEach(b=>b.classList.toggle('on',+b.dataset.s===_rtTotal));
  clearInterval(_rtInt);
  _rtInt=setInterval(()=>{
    _rtRemain--;
    if(_rtRemain<=0){clearInterval(_rtInt);_rtRunning=false;_rtRemain=0;restDone();}
    renderRest();
  },1000);
  renderRest();
}
function pauseRest(){
  if(_rtRunning){clearInterval(_rtInt);_rtRunning=false;}
  else { startRestTimer(_rtRemain>0?_rtRemain:_rtPreset,false); }
  renderRest();
}
function resetRest(){clearInterval(_rtInt);_rtRunning=false;_rtRemain=_rtTotal;document.getElementById('rest-panel').classList.remove('done');renderRest();}
function addRest(sec){_rtRemain+=sec;if(_rtRemain>_rtTotal)_rtTotal=_rtRemain;renderRest();}
function restDone(){
  const p=document.getElementById('rest-panel');p.classList.add('show','done');
  if(navigator.vibrate)navigator.vibrate([200,100,200]);
  restBeep(); toast('⏱️ Rest over — next set!');
}
function restBeep(){
  try{const ctx=new (window.AudioContext||window.webkitAudioContext)();
    [0,0.18].forEach(t=>{const o=ctx.createOscillator(),g=ctx.createGain();
      o.connect(g);g.connect(ctx.destination);o.type='sine';o.frequency.value=880;
      const st=ctx.currentTime+t;
      g.gain.setValueAtTime(0.0001,st);g.gain.exponentialRampToValueAtTime(0.3,st+0.02);
      g.gain.exponentialRampToValueAtTime(0.0001,st+0.14);
      o.start(st);o.stop(st+0.15);});
  }catch(e){}
}
function renderRest(){
  const t=document.getElementById('rt-time');if(!t)return;
  t.textContent=fmtT(_rtRemain);
  document.getElementById('rt-fill').style.width=(_rtTotal?(_rtRemain/_rtTotal*100):0)+'%';
  document.getElementById('rt-toggle').textContent=_rtRunning?'⏸ Pause':((_rtRemain<_rtTotal&&_rtRemain>0)?'▶ Resume':'▶ Start');
}

// ═══════════ STRENGTH PROGRESSION CHART ═══════════
let _progEx=null;
function strengthExNames(){
  const cnt={};
  workouts.filter(w=>w.type==='strength'&&w.exercise&&w.weight>0).forEach(w=>{cnt[w.exercise]=(cnt[w.exercise]||0)+1;});
  return Object.keys(cnt).sort((a,b)=>cnt[b]-cnt[a]);
}
function selProgEx(v){_progEx=v;renderProgChart();}
function renderProgChart(){
  const wrap=document.getElementById('prog-wrap'),sel=document.getElementById('prog-sel');
  if(!wrap||!sel)return;
  const names=strengthExNames();
  if(!names.length){sel.innerHTML='';wrap.innerHTML='<div style="text-align:center;padding:14px;font-size:13px;color:var(--text2)">Log strength workouts to track progression</div>';return;}
  if(!_progEx||!names.includes(_progEx))_progEx=names[0];
  sel.innerHTML=names.map(n=>`<option value="${n.replace(/"/g,'&quot;')}" ${n===_progEx?'selected':''}>${n}</option>`).join('');
  svgProgLine(wrap,_progEx);
}
function svgProgLine(container,name){
  const list=workouts.filter(w=>w.type==='strength'&&w.exercise&&w.exercise.toLowerCase()===name.toLowerCase()&&w.weight>0)
    .sort((a,b)=>a.date.localeCompare(b.date)).slice(-20);
  if(list.length<2){container.innerHTML='<div style="text-align:center;padding:14px;font-size:13px;color:var(--text2)">Need 2+ logged sessions of this lift</div>';return;}
  const pts0=list.map(w=>({v:est1RM(w.weight,w.reps),d:w.date}));
  const vals=pts0.map(p=>p.v),minV=Math.min(...vals),maxV=Math.max(...vals),range=maxV-minV||1;
  const W=container.clientWidth||340,H=130,PAD=34;
  const pts=pts0.map((p,i)=>({x:PAD+(i/(pts0.length-1))*(W-PAD*2),y:12+(1-(p.v-minV)/range)*(H-36)}));
  const path=pts.map((p,i)=>i===0?`M${p.x},${p.y}`:`L${p.x},${p.y}`).join(' ');
  const area=`${path} L${pts[pts.length-1].x},${H-14} L${pts[0].x},${H-14} Z`;
  const dots=pts.map(p=>`<circle cx="${p.x}" cy="${p.y}" r="3" fill="#0fbcb0"/>`).join('');
  const yl=`<text x="2" y="14" class="chart-label" fill="#0a756d">${maxV}</text><text x="2" y="${H-16}" class="chart-label" fill="#0a756d">${minV}</text>`;
  const delta=pts0[pts0.length-1].v-pts0[0].v;
  container.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
      <div style="font-size:12px;color:var(--text2)">Est. 1RM (kg)</div>
      <div style="font-size:12px;font-weight:700;color:${delta>=0?'var(--green)':'var(--coral-dark)'}">${delta>=0?'+':''}${delta}kg since start</div></div>
    <svg viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">
      <defs><linearGradient id="pg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0fbcb0" stop-opacity=".25"/><stop offset="100%" stop-color="#0fbcb0" stop-opacity="0"/></linearGradient></defs>
      <path d="${area}" fill="url(#pg)"/><path d="${path}" class="chart-line" stroke="#0fbcb0"/>${dots}${yl}
    </svg>`;
}

// ═══════════ ASK CLAUDE ═══════════
function buildCoachPrompt(){
  const xp=totalXP(workouts),lv=lvData(xp),streak=calcStreak(workouts);
  const last14=workouts.filter(w=>(Date.now()-new Date(w.date))/864e5<=14);
  const strength=workouts.filter(w=>w.type==='strength'&&w.weight>0);
  const best={};
  strength.forEach(w=>{const e=est1RM(w.weight,w.reps);if(!best[w.exercise]||e>best[w.exercise])best[w.exercise]=e;});
  const lifts=Object.entries(best).sort((a,b)=>b[1]-a[1]).slice(0,6).map(([n,v])=>`${n} ~${v}kg`).join(', ');
  const bw=weights.length?[...weights].sort((a,b)=>b.date.localeCompare(a.date))[0].weight:null;
  let p='I track my training in a fitness app and want coaching advice. My recent data:\n';
  p+=`- Level ${lv.level} (${lv.title}), ${xp} XP, ${streak}-day streak\n`;
  p+=`- ${last14.length} workouts in the last 14 days, ${workouts.length} all-time\n`;
  if(bw)p+=`- Bodyweight: ${bw}kg\n`;
  if(lifts)p+=`- Estimated 1RMs: ${lifts}\n`;
  if(profile&&profile.goal)p+=`- Goal: ${profile.goal}\n`;
  p+='\nWhat should I focus on next? Give specific progression advice, flag any muscle imbalances or gaps, and outline how to structure my next 2 weeks of training.';
  return p;
}
function askClaude(custom){
  const prompt=custom||buildCoachPrompt();
  try{if(navigator.clipboard)navigator.clipboard.writeText(prompt);}catch(e){}
  window.open('https://claude.ai/new?q='+encodeURIComponent(prompt),'_blank');
  toast('💬 Opening Claude — prompt copied too');
}
function askClaudeExercise(){
  const name=(document.getElementById('wi-ex').value||'').trim();
  if(!name){toast('⚠️ Enter an exercise first');return;}
  const last=lastSessionFor(name),pr=getPersonalRecord(name);
  let p=`I'm training "${name}". `;
  if(last)p+=`Last session: ${last.sets||0}×${last.reps||0}${last.weight?` @ ${last.weight}kg`:''}. `;
  if(pr)p+=`My PR is ${pr}kg. `;
  p+='How should I progress this lift? Give sets/reps/weight recommendations, key form cues, and common mistakes to avoid.';
  askClaude(p);
}

