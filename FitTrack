  {id:'lazy-sunday',ico:'🛋️', name:'Lazy Sunday Pass',  desc:'Do absolutely nothing. Full recharge day.',     color:'#4ade80', bg:'rgba(74,222,128,.18)',  earnEvery:3,  metric:'streak',   label:'per 3-day streak'},
