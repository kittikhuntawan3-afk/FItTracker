// ── TDEE / Nutrition ──
function calcTDEE(){
  const p=profile;
  if(!p.age||!p.height||!p.weight||!p.gender)return null;
  const w=parseFloat(p.weight),h=parseFloat(p.height),a=parseInt(p.age);
  // Mifflin-St Jeor BMR
  const bmr=p.gender==='m'?(10*w+6.25*h-5*a+5):(10*w+6.25*h-5*a-161);
  const tdee=Math.round(bmr*parseFloat(p.activity||1.55));
  const adj=p.goal==='cut'?-300:p.goal==='bulk'?300:0;
  return {tdee, target:tdee+adj, bmr:Math.round(bmr)};
}
function isWorkoutDay(){
  const dow=todayDowKey();
  const ap=plans.find(p=>p.active);
  if(ap)return ap.days.some(d=>d.schedule&&d.schedule.includes(dow));
  // fallback: check if any workout logged today
  return workouts.some(w=>w.date===today());
}
function calcProtein(){
  const w=parseFloat(profile.weight)||0;
  if(!w)return null;
  const gPerKg=isWorkoutDay()?2.2:1.6;
  return {grams:Math.round(w*gPerKg), gPerKg, workout:isWorkoutDay()};
}
function openTDEESheet(){
  const p=profile;
  if(p.age)document.getElementById('td-age').value=p.age;
  if(p.gender)document.getElementById('td-gender').value=p.gender;
  if(p.height)document.getElementById('td-height').value=p.height;
  // prefill weight from last body weight log if not set
  const w=p.weight||(weights.length?[...weights].sort((a,b)=>b.date.localeCompare(a.date))[0].weight:'');
  if(w)document.getElementById('td-weight').value=w;
  if(p.activity)document.getElementById('td-activity').value=p.activity;
  if(p.goal)document.getElementById('td-goal').value=p.goal;
  openSheet('s-tdee');
}
function saveTDEEProfile(){
  const age=parseInt(document.getElementById('td-age').value);
  const height=parseFloat(document.getElementById('td-height').value);
  const weight=parseFloat(document.getElementById('td-weight').value);
  if(!age||!height||!weight){toast('⚠️ Fill in all fields');return;}
  profile={
    age, height, weight,
    gender:document.getElementById('td-gender').value,
    activity:document.getElementById('td-activity').value,
