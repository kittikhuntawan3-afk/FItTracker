// ICS export
function exportPlanICS(planId){
  const p=plans.find(x=>x.id===planId);
  if(!p){toast('⚠️ Plan not found');return;}
  const scheduled=p.days.filter(d=>d.schedule&&d.schedule.length);
  if(!scheduled.length){toast('⚠️ No scheduled days in plan');return;}
  const dowNum={sun:0,mon:1,tue:2,wed:3,thu:4,fri:5,sat:6};
  let ics='BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//FitTracker//EN\r\nCALSCALE:GREGORIAN\r\nX-WR-CALNAME:'+p.name+'\r\n';
  const now=new Date();
  scheduled.forEach(d=>{
    const exList=d.exercises.map(ex=>{
      const isS=ex.type==='strength';
      return isS?`${ex.name} ${ex.sets||''}×${ex.reps||''}${ex.weight?' @ '+ex.weight+'kg':''}`:`${ex.name}${ex.duration?' '+ex.duration+'min':''}`;
    }).join('\\n');
    const desc=(p.name+' – '+d.name+(exList?'\\n\\n'+exList:'')).replace(/,/g,'\\,');
    d.schedule.forEach(key=>{
      const target=dowNum[key]??1;
      const cur=now.getDay();
      let diff=target-cur;if(diff<=0)diff+=7; // next occurrence
      const start=new Date(now);start.setDate(now.getDate()+diff);
      const ds=start.toISOString().split('T')[0].replace(/-/g,'');
      const end=new Date(start);end.setDate(start.getDate()+1);
      const de=end.toISOString().split('T')[0].replace(/-/g,'');
      ics+=`BEGIN:VEVENT\r\nDTSTART;VALUE=DATE:${ds}\r\nDTEND;VALUE=DATE:${de}\r\nSUMMARY:${p.icon} ${d.name}\r\nDESCRIPTION:${desc}\r\nRRULE:FREQ=WEEKLY;COUNT=12\r\nEND:VEVENT\r\n`;
    });
  });
  ics+='END:VCALENDAR';
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([ics],{type:'text/calendar'}));
  a.download=(p.name.replace(/\s+/g,'_')||'plan')+'.ics';
  a.click();toast('📥 Plan exported! Import into Google Calendar.');
}

function exportICS(){
  if(!workouts.length){toast('⚠️ No workouts');return;}
  let ics='BEGIN:VCALENDAR\r\nVERSION:2.0\r\nPRODID:-//FitTracker//EN\r\nCALSCALE:GREGORIAN\r\n';
  workouts.forEach(w=>{
    const d=w.date.replace(/-/g,'');
    const nm=w.type==='strength'?`💪 ${w.exercise}`:`🏃 ${w.activity}`;
    const desc=w.type==='strength'?`${w.sets}×${w.reps} @ ${w.weight}kg`:`${w.duration}min ${w.distance}km`;
    ics+=`BEGIN:VEVENT\r\nDTSTART;VALUE=DATE:${d}\r\nDTEND;VALUE=DATE:${d}\r\nSUMMARY:${nm}\r\nDESCRIPTION:${desc} (+${w.xp}XP)\r\nEND:VEVENT\r\n`;
  });
  ics+='END:VCALENDAR';
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([ics],{type:'text/calendar'}));
  a.download='FitTracker.ics';a.click();toast('📥 Exported!');
}

