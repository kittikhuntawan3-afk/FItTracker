  w.xp=calcXP(w);
  const prevXP=totalXP(workouts),prevLv=lvData(prevXP).level;
  workouts.push(w);save();
  const newLv=lvData(totalXP(workouts)).level;
  closeSheet('s-workout');refreshAll();
